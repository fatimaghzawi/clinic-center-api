{
  "info": {
    "name": "Clinic Center API",
    "description": "MongoDB Clinic Management System API.\n\n## Setup\n1. Run `npm run dev` and `npm run seed`.\n2. Import this collection into Postman.\n3. Run **Auth → Login (run first)** — auth uses httpOnly cookies. Postman stores and sends them automatically.\n4. Follow this order for end-to-end testing:\n   Login → Register Doctor User → Create Department → Create Patient → Create Staff\n\n## Seed admin\n- Username: `admin`\n- Password: `Admin@123456`\n\n## Password rules (register)\nMin 8 chars, uppercase, lowercase, number, and special character (e.g. `Doctor@123`).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "departmentId", "value": "" },
    { "key": "patientId", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "staffId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (run first)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Login successful', () => pm.expect(json.success).to.be.true);",
                  "pm.test('Auth cookies set', () => {",
                  "  pm.expect(pm.cookies.has('access_token')).to.be.true;",
                  "  pm.expect(pm.cookies.has('refresh_token')).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin@123456\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Register Doctor User (admin only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const id = pm.response.json().data?.id;",
                  "  if (id) pm.collectionVariables.set('userId', id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"doctor1\",\n  \"password\": \"Doctor@123\",\n  \"role\": \"doctor\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Register Receptionist User (admin only)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"reception1\",\n  \"password\": \"Reception@123\",\n  \"role\": \"receptionist\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Access cookie refreshed', () => pm.expect(pm.cookies.has('access_token')).to.be.true);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/auth/refresh"
          }
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/users?page=1&limit=10"
          }
        },
        {
          "name": "Get User By Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/users/{{userId}}"
          }
        }
      ]
    },
    {
      "name": "Departments",
      "item": [
        {
          "name": "Create Department",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const id = pm.response.json().data?._id;",
                  "  if (id) pm.collectionVariables.set('departmentId', id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"departmentName\": \"Cardiology\",\n  \"description\": \"Heart and vascular care\"\n}"
            },
            "url": "{{baseUrl}}/departments"
          }
        },
        {
          "name": "Get All Departments",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/departments?page=1&limit=10"
          }
        },
        {
          "name": "Get Department By Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/departments/{{departmentId}}"
          }
        },
        {
          "name": "Update Department",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Updated description\"\n}"
            },
            "url": "{{baseUrl}}/departments/{{departmentId}}"
          }
        },
        {
          "name": "Delete Department",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/departments/{{departmentId}}"
          }
        }
      ]
    },
    {
      "name": "Patients",
      "item": [
        {
          "name": "Create Patient",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const id = pm.response.json().data?._id;",
                  "  if (id) pm.collectionVariables.set('patientId', id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Fatima Ali\",\n  \"phone\": \"03123456\",\n  \"email\": \"fatima@example.com\",\n  \"gender\": \"Female\",\n  \"dateOfBirth\": \"1990-05-12\",\n  \"address\": \"Beirut\",\n  \"bloodGroup\": \"O+\",\n  \"emergencyContact\": \"Layla Ali\"\n}"
            },
            "url": "{{baseUrl}}/patients"
          }
        },
        {
          "name": "Get All Patients",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/patients?page=1&limit=10&search=fatima"
          }
        },
        {
          "name": "Get Patient By Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/patients/{{patientId}}"
          }
        },
        {
          "name": "Update Patient",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"address\": \"New Address\"\n}"
            },
            "url": "{{baseUrl}}/patients/{{patientId}}"
          }
        },
        {
          "name": "Delete Patient",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/patients/{{patientId}}"
          }
        }
      ]
    },
    {
      "name": "Staff",
      "item": [
        {
          "name": "Create Staff",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const id = pm.response.json().data?._id;",
                  "  if (id) pm.collectionVariables.set('staffId', id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"departmentId\": \"{{departmentId}}\",\n  \"staffType\": \"doctor\",\n  \"fullName\": \"Dr. Samir Hassan\",\n  \"specialization\": \"Cardiology\",\n  \"phone\": \"03987654\",\n  \"email\": \"samir@clinic.example.com\",\n  \"gender\": \"Male\"\n}"
            },
            "url": "{{baseUrl}}/staff"
          }
        },
        {
          "name": "Get All Staff",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/staff?page=1&limit=10"
          }
        },
        {
          "name": "Get Staff By Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/staff/{{staffId}}"
          }
        }
      ]
    }
  ]
}
